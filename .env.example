# RevenueCat Charts API key (V2, scope: charts_metrics:*:read)
# Never commit the real key. Copy this file to .env and fill in locally.
RC_CHARTS_API_KEY=sk_your_key_here

# Project ID for the target RevenueCat project (Dark Noise for this submission)
RC_PROJECT_ID=

# Anthropic key for the web playground and eval harness
ANTHROPIC_API_KEY=sk-ant-your_key_here
